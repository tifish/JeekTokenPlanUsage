# Build output. `bin/*` rather than `bin/` so the directory itself is
# traversed and the AutoUpdate.ps1 exception below can re-include one file.
bin/*
obj/
[Dd]ebug/
[Rr]elease/
x64/
x86/

# These scripts live in bin/ as the canonical tracked copies (the updater plus
# the .NET runtime setup). Re-include them while the rest of bin/ stays ignored.
!bin/AutoUpdate.ps1
!bin/Setup.cmd
!bin/dotnet-install.ps1

# Publish artifacts
*.7z
*.zip

# CI-only artifact written by the workflow into the runner workspace; never
# meant to be committed. Listed here as a tripwire in case someone runs the
# version.txt-writing PowerShell locally while debugging.
version.txt

# Visual Studio / Rider / VS Code
.vs/
.vscode/
.idea/
*.user
*.suo
*.userosscache
*.sln.docstates

# Local settings
*.local.json
appsettings.Development.json
.claude/settings.local.json
Deploy.cmd

# OS
Thumbs.db
.DS_Store

# Logs
*.log
